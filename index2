<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💕 Manual de Convivencia y Conexión</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
:root {
  --cream: #FAF6F0;
  --rose: #C9715A;
  --rose-light: #F2DDD6;
  --burgundy: #7A2D3B;
  --gold: #C9963A;
  --gold-light: #F5ECD9;
  --sage: #6B8F71;
  --sage-light: #DFF0E1;
  --plum: #5C3D6E;
  --plum-light: #EAE0F5;
  --text: #2C1A1A;
  --text-muted: #7A6060;
  --white: #FFFFFF;
  --border: #E8DDD5;
  --shadow: 0 4px 24px rgba(122,45,59,0.08);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'DM Sans', sans-serif;
  background: var(--cream);
  color: var(--text);
  min-height: 100vh;
}
h1,h2,h3,h4 { font-family: 'Playfair Display', serif; }

/* ─── LAYOUT ─── */
.app { display: flex; min-height: 100vh; }

/* ─── SIDEBAR ─── */
.sidebar {
  width: 260px;
  background: var(--burgundy);
  display: flex;
  flex-direction: column;
  position: fixed;
  top: 0; left: 0; height: 100vh;
  overflow-y: auto;
  z-index: 100;
  transition: transform 0.3s;
}
.sidebar-logo {
  padding: 28px 24px 20px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.sidebar-logo h1 {
  color: #fff;
  font-size: 18px;
  line-height: 1.3;
}
.sidebar-logo p {
  color: rgba(255,255,255,0.55);
  font-size: 11px;
  margin-top: 4px;
}
.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 24px;
  color: rgba(255,255,255,0.65);
  cursor: pointer;
  font-size: 13px;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}
.nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }
.nav-item.active {
  background: rgba(255,255,255,0.1);
  color: #fff;
  border-left-color: var(--gold);
}
.nav-icon { font-size: 16px; width: 20px; text-align: center; }
.nav-save {
  margin: auto 16px 16px;
  padding: 10px;
  background: var(--gold);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  width: calc(100% - 32px);
  transition: background 0.2s;
}
.nav-save:hover { background: #b5852e; }
.save-indicator {
  text-align: center;
  font-size: 11px;
  color: rgba(255,255,255,0.4);
  padding-bottom: 8px;
}

/* ─── MAIN ─── */
.main {
  margin-left: 260px;
  flex: 1;
  padding: 40px 48px;
  max-width: 960px;
}
.page { display: none; animation: fadeIn 0.3s; }
.page.active { display: block; }
@keyframes fadeIn { from { opacity:0; transform: translateY(8px); } to { opacity:1; transform: none; } }

/* ─── PAGE HEADER ─── */
.page-header {
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}
.page-header h2 { font-size: 32px; color: var(--burgundy); }
.page-header p { color: var(--text-muted); font-size: 14px; margin-top: 6px; font-style: italic; }

/* ─── CARDS ─── */
.card {
  background: var(--white);
  border-radius: 16px;
  padding: 24px;
  box-shadow: var(--shadow);
  margin-bottom: 20px;
  border: 1px solid var(--border);
}
.card-title {
  font-family: 'Playfair Display', serif;
  font-size: 18px;
  color: var(--burgundy);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

/* ─── GRID ─── */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }

/* ─── FORM ELEMENTS ─── */
label {
  display: block;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 6px;
}
input[type=text], input[type=date], input[type=number], textarea, select {
  width: 100%;
  padding: 10px 14px;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: var(--text);
  background: var(--cream);
  transition: border-color 0.2s;
  resize: vertical;
}
input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--rose);
  background: #fff;
}
.field { margin-bottom: 16px; }
textarea { min-height: 80px; }

/* ─── PERSON COLUMNS ─── */
.person-col {
  background: var(--cream);
  border-radius: 12px;
  padding: 20px;
}
.person-col.p1 { border-top: 4px solid var(--rose); }
.person-col.p2 { border-top: 4px solid var(--plum); }
.person-col h3 {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.person-col.p1 h3 { color: var(--rose); }
.person-col.p2 h3 { color: var(--plum); }

/* ─── STEPS ─── */
.step-item {
  display: flex;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--border);
}
.step-item:last-child { border-bottom: none; }
.step-num {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 15px;
  flex-shrink: 0;
  color: #fff;
}
.step-content h4 { font-size: 15px; font-family: 'DM Sans',sans-serif; font-weight: 500; margin-bottom: 4px; }
.step-content p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

/* ─── TAGS ─── */
.tag {
  display: inline-block;
  padding: 3px 12px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  margin: 3px;
}
.tag-rose { background: var(--rose-light); color: var(--rose); }
.tag-gold { background: var(--gold-light); color: #8a6520; }
.tag-sage { background: var(--sage-light); color: #3b6b41; }
.tag-plum { background: var(--plum-light); color: var(--plum); }
.tag-red { background: #fde8e8; color: #c0392b; }

/* ─── TABLE ─── */
table { width: 100%; border-collapse: collapse; font-size: 13px; }
th {
  background: var(--burgundy);
  color: #fff;
  padding: 10px 14px;
  text-align: left;
  font-weight: 500;
  font-size: 12px;
  font-family: 'DM Sans', sans-serif;
}
td {
  padding: 10px 14px;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}
tr:nth-child(even) td { background: var(--cream); }
tr:last-child td { border-bottom: none; }

/* ─── RATING ─── */
.rating-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.rating-row:last-child { border-bottom: none; }
.rating-label { flex: 1; font-size: 14px; }
.rating-input { width: 70px; }
.rating-bar {
  flex: 1;
  height: 6px;
  background: var(--border);
  border-radius: 3px;
  overflow: hidden;
}
.rating-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--rose), var(--gold));
  border-radius: 3px;
  transition: width 0.3s;
}

/* ─── PORTADA ─── */
.portada-hero {
  background: linear-gradient(135deg, var(--burgundy), var(--plum));
  border-radius: 20px;
  padding: 48px;
  text-align: center;
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
}
.portada-hero::before {
  content: '❤';
  position: absolute;
  font-size: 200px;
  opacity: 0.04;
  top: -30px;
  right: -20px;
}
.portada-hero h1 { color: #fff; font-size: 36px; line-height: 1.2; margin-bottom: 10px; }
.portada-hero p { color: rgba(255,255,255,0.65); font-style: italic; font-size: 15px; }
.portada-heart { font-size: 48px; margin-bottom: 16px; display: block; }
.signature-box {
  border: 2px dashed var(--border);
  border-radius: 12px;
  padding: 20px;
  text-align: center;
  min-height: 100px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  gap: 8px;
}
.signature-line { width: 80%; border-bottom: 1.5px solid var(--text); padding-bottom: 4px; font-size: 13px; color: var(--text-muted); }

/* ─── BUCKET LIST ─── */
.bucket-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
}
.bucket-item:last-child { border-bottom: none; }
.bucket-check {
  width: 22px; height: 22px;
  border: 2px solid var(--border);
  border-radius: 50%;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  flex-shrink: 0;
  transition: all 0.2s;
}
.bucket-check.done { background: var(--sage); border-color: var(--sage); color: #fff; }
.bucket-text { flex: 1; font-size: 14px; }
.bucket-text.done { text-decoration: line-through; color: var(--text-muted); }

/* ─── CAGADAS TRACKER ─── */
.cagada-row {
  display: grid;
  grid-template-columns: 40px 1fr 120px 90px 90px;
  gap: 10px;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
  align-items: center;
}
.cagada-num {
  width: 28px; height: 28px;
  background: var(--rose-light);
  color: var(--rose);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 600;
}
.cagada-row input, .cagada-row select { margin-bottom: 0; font-size: 13px; }
.emoji-level { font-size: 18px; }

/* ─── CHART CONTAINER ─── */
.chart-wrap {
  position: relative;
  height: 280px;
  margin-top: 16px;
}

/* ─── RITUAL CARD ─── */
.ritual-card {
  background: var(--cream);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  border-left: 4px solid var(--gold);
  display: flex;
  gap: 12px;
  align-items: flex-start;
}
.ritual-emoji { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
.ritual-body { flex: 1; }
.ritual-body h4 { font-size: 14px; font-weight: 500; margin-bottom: 4px; }
.ritual-body p { font-size: 12px; color: var(--text-muted); }
.ritual-freq {
  font-size: 11px;
  background: var(--gold-light);
  color: #8a6520;
  padding: 2px 8px;
  border-radius: 100px;
  font-weight: 500;
  white-space: nowrap;
}

/* ─── CONTRATO ─── */
.contrato-art {
  background: linear-gradient(135deg, #fffdf9, #fdf5ec);
  border: 2px solid var(--gold);
  border-radius: 20px;
  padding: 40px;
  text-align: center;
  position: relative;
}
.contrato-art::before, .contrato-art::after {
  content: '✦';
  position: absolute;
  font-size: 20px;
  color: var(--gold);
  opacity: 0.4;
}
.contrato-art::before { top: 16px; left: 20px; }
.contrato-art::after { bottom: 16px; right: 20px; }
.contrato-art h2 { color: var(--burgundy); font-size: 26px; margin-bottom: 8px; }
.contrato-art .sub { font-style: italic; color: var(--text-muted); font-size: 13px; margin-bottom: 28px; }
.promesa {
  text-align: left;
  background: rgba(255,255,255,0.7);
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 24px;
}
.promesa p {
  padding: 8px 0;
  border-bottom: 1px dashed var(--border);
  font-size: 14px;
  line-height: 1.6;
  display: flex;
  gap: 10px;
}
.promesa p:last-child { border-bottom: none; }
.promesa span { color: var(--gold); font-weight: 600; }
.firma-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 24px; }
.firma-box {
  border-top: 2px solid var(--text);
  padding-top: 8px;
  text-align: center;
  font-size: 12px;
  color: var(--text-muted);
}

/* ─── MOBILE TOGGLE ─── */
.menu-toggle {
  display: none;
  position: fixed;
  top: 16px; left: 16px;
  z-index: 200;
  background: var(--burgundy);
  color: #fff;
  border: none;
  border-radius: 8px;
  padding: 8px 12px;
  cursor: pointer;
  font-size: 18px;
}

/* ─── DASHBOARD STAT ─── */
.stat-card {
  background: var(--white);
  border-radius: 12px;
  padding: 20px;
  border: 1px solid var(--border);
  text-align: center;
}
.stat-num { font-size: 36px; font-family: 'Playfair Display', serif; color: var(--burgundy); }
.stat-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

/* ─── PROGRESS ─── */
.progress-wrap { margin-bottom: 12px; }
.progress-label { display: flex; justify-content: space-between; font-size: 13px; margin-bottom: 4px; }
.progress-bar { height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, var(--rose), var(--gold)); transition: width 0.5s; }

/* ─── RESPONSIVE ─── */
@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: none; }
  .main { margin-left: 0; padding: 20px; padding-top: 60px; }
  .grid-2 { grid-template-columns: 1fr; }
  .grid-3 { grid-template-columns: 1fr; }
  .menu-toggle { display: block; }
  .cagada-row { grid-template-columns: 30px 1fr 80px; }
  .firma-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<button class="menu-toggle" onclick="toggleMenu()">☰</button>

<div class="app">
<!-- ══ SIDEBAR ══ -->
<nav class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <h1>💕 Manual de Convivencia</h1>
    <p>Nuestra historia de amor</p>
  </div>
  <div id="nav-items">
    <div class="nav-item active" onclick="nav('portada')"><span class="nav-icon">🏠</span> Portada</div>
    <div class="nav-item" onclick="nav('perfiles')"><span class="nav-icon">🧬</span> Perfiles</div>
    <div class="nav-item" onclick="nav('mision')"><span class="nav-icon">🎯</span> Misión & Visión</div>
    <div class="nav-item" onclick="nav('conflictos')"><span class="nav-icon">⚡</span> Protocolo Conflictos</div>
    <div class="nav-item" onclick="nav('amor')"><span class="nav-icon">💝</span> Lenguajes del Amor</div>
    <div class="nav-item" onclick="nav('convivencia')"><span class="nav-icon">🏡</span> Convivencia</div>
    <div class="nav-item" onclick="nav('limites')"><span class="nav-icon">🚩</span> Límites</div>
    <div class="nav-item" onclick="nav('rituales')"><span class="nav-icon">🕯️</span> Rituales</div>
    <div class="nav-item" onclick="nav('cagadas')"><span class="nav-icon">📊</span> Rastreador Cagadas</div>
    <div class="nav-item" onclick="nav('revision')"><span class="nav-icon">🔄</span> Revisión Trimestral</div>
    <div class="nav-item" onclick="nav('dashboard')"><span class="nav-icon">📈</span> Dashboard</div>
    <div class="nav-item" onclick="nav('bucket')"><span class="nav-icon">✈️</span> Bucket List</div>
    <div class="nav-item" onclick="nav('agradecimientos')"><span class="nav-icon">🙏</span> Agradecimientos</div>
    <div class="nav-item" onclick="nav('contrato')"><span class="nav-icon">📜</span> Contrato de Amor</div>
  </div>
  <div style="margin-top:auto; padding: 16px 16px 0;">
    <button class="nav-save" onclick="saveAll()">💾 Guardar todo</button>
    <p class="save-indicator" id="save-status">Los datos se guardan automáticamente</p>
  </div>
</nav>

<!-- ══ MAIN CONTENT ══ -->
<main class="main">

<!-- ───── PORTADA ───── -->
<div class="page active" id="page-portada">
  <div class="portada-hero">
    <span class="portada-heart">💕</span>
    <h1>Manual de Convivencia y Conexión</h1>
    <p>El reglamento oficial de nuestra historia de amor</p>
  </div>
  <div class="card">
    <div class="card-title">👥 Datos de la Pareja</div>
    <div class="grid-2">
      <div class="person-col p1">
        <h3>💙 Persona 1</h3>
        <div class="field"><label>Nombre o apodo</label><input type="text" id="p1-nombre" placeholder="Tu nombre..."></div>
        <div class="field"><label>Fecha de nacimiento</label><input type="date" id="p1-fecha"></div>
        <div class="field"><label>Lo que más amo de ti</label><textarea id="p1-amor" placeholder="Escribe aquí..." rows="3"></textarea></div>
        <div class="field"><label>Mi compromiso contigo</label><textarea id="p1-compromiso" placeholder="Tu promesa..." rows="3"></textarea></div>
      </div>
      <div class="person-col p2">
        <h3>💜 Persona 2</h3>
        <div class="field"><label>Nombre o apodo</label><input type="text" id="p2-nombre" placeholder="Su nombre..."></div>
        <div class="field"><label>Fecha de nacimiento</label><input type="date" id="p2-fecha"></div>
        <div class="field"><label>Lo que más amo de ti</label><textarea id="p2-amor" placeholder="Escribe aquí..." rows="3"></textarea></div>
        <div class="field"><label>Mi compromiso contigo</label><textarea id="p2-compromiso" placeholder="Su promesa..." rows="3"></textarea></div>
      </div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">📋 Datos del Documento</div>
    <div class="grid-2">
      <div class="field"><label>Fecha de creación</label><input type="date" id="doc-fecha"></div>
      <div class="field"><label>Versión</label><input type="text" id="doc-version" placeholder="v1.0"></div>
      <div class="field"><label>Lugar de firma</label><input type="text" id="doc-lugar" placeholder="Ciudad, país..."></div>
      <div class="field"><label>Próxima revisión</label><input type="date" id="doc-revision"></div>
    </div>
  </div>
  <div class="card">
    <div class="card-title">✍️ Firmas de Compromiso</div>
    <div class="firma-grid">
      <div class="signature-box">
        <div style="flex:1"></div>
        <div class="signature-line">Firma Persona 1</div>
        <div style="font-size:11px;color:var(--text-muted)" id="firma-p1-name">___________________</div>
      </div>
      <div class="signature-box">
        <div style="flex:1"></div>
        <div class="signature-line">Firma Persona 2</div>
        <div style="font-size:11px;color:var(--text-muted)" id="firma-p2-name">___________________</div>
      </div>
    </div>
  </div>
</div>

<!-- ───── PERFILES ───── -->
<div class="page" id="page-perfiles">
  <div class="page-header">
    <h2>🧬 Perfiles de Pareja</h2>
    <p>Conócete y conoce a tu amor a fondo</p>
  </div>

  <script>
  const perfilSections = [
    {id:'personalidad', icon:'🌟', title:'Personalidad'},
    {id:'lenguaje', icon:'💬', title:'Lenguaje del amor'},
    {id:'likes', icon:'✅', title:'Likes (lo que me encanta)'},
    {id:'dislikes', icon:'❌', title:'Dislikes (lo que me molesta)'},
    {id:'negociables', icon:'🤝', title:'Negociables'},
    {id:'nonneg', icon:'🚫', title:'No negociables (límites)'},
    {id:'metas', icon:'🎯', title:'Metas personales'},
    {id:'miedos', icon:'💭', title:'Miedos / Inseguridades'},
    {id:'muestro', icon:'🥰', title:'Cómo muestro amor'},
    {id:'reacciono', icon:'😤', title:'Cómo reacciono al conflicto'},
  ];
  document.write(perfilSections.map(s => `
  <div class="card">
    <div class="card-title">${s.icon} ${s.title}</div>
    <div class="grid-2">
      <div class="person-col p1"><h3>💙 Persona 1</h3>
        <textarea id="p1-${s.id}" placeholder="Escribe aquí..." rows="4"></textarea>
      </div>
      <div class="person-col p2"><h3>💜 Persona 2</h3>
        <textarea id="p2-${s.id}" placeholder="Escribe aquí..." rows="4"></textarea>
      </div>
    </div>
  </div>`).join(''));
  </script>
</div>

<!-- ───── MISIÓN ───── -->
<div class="page" id="page-mision">
  <div class="page-header">
    <h2>🎯 Misión, Visión y Valores</h2>
    <p>El propósito de nuestra relación</p>
  </div>
  <div class="card">
    <div class="card-title">💫 Misión de la Pareja</div>
    <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">¿Por qué estamos juntos? ¿Qué propósito tiene nuestra relación?</p>
    <textarea id="mision-texto" rows="5" placeholder="Ej: Somos dos personas que decidimos construir un amor basado en el respeto, la risa y el crecimiento mutuo..."></textarea>
  </div>
